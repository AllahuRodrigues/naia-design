# Auto detect text files and perform LF normalization
* text=auto

# Large binary files
*.pkg binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.rar binary
*.7z binary

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
*.ico binary

# Audio files
*.mp3 binary
*.wav binary
*.ogg binary

# Video files
*.mp4 binary
*.webm binary
*.mov binary

# Document files
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary 